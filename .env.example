APP_NAME=Trust Index API
API_PREFIX=/api/v1
# Supabase Postgres example:
# DATABASE_URL=postgresql+psycopg://postgres:<YOUR-PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
DB_AUTO_CREATE=false

# Admin URL is only for one-time provisioning/migration scripts.
# Keep runtime DATABASE_URL pointed to a least-privilege role.
ADMIN_DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres?sslmode=require
APP_DB_ROLE=trust_index_app
APP_DB_PASSWORD=replace-with-strong-password
SUPABASE_PROJECT_REF=project-ref
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2

# Spending discipline thresholds
IMPULSE_INCOME_PCT=0.12
DISCRETIONARY_DEVIATION_MULTIPLIER=1.8

# Commitment reliability thresholds
COMMITMENT_ON_TIME_GRACE_DAYS=4

# Financial resilience thresholds
EMERGENCY_SHOCK_INCOME_PCT=0.15
RECOVERY_CAP_MONTHS=6
