APP_NAME=Trust Index API
API_PREFIX=/api/v1
MYSQL_URL=mysql+pymysql://root:password@localhost:3306/trust_index
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=45
AI_MAX_RETRIES=2

# Spending discipline thresholds
IMPULSE_INCOME_PCT=0.12
DISCRETIONARY_DEVIATION_MULTIPLIER=1.8

# Commitment reliability thresholds
COMMITMENT_ON_TIME_GRACE_DAYS=4

# Financial resilience thresholds
EMERGENCY_SHOCK_INCOME_PCT=0.15
RECOVERY_CAP_MONTHS=6
